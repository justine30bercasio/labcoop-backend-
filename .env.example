# Server port
PORT=3000

# Environment (development or production)
# In production, the server will refuse to start without valid secrets below.
NODE_ENV=development

# ── REQUIRED IN PRODUCTION ──

# JWT secret — generate a secure random string:
#   openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Session secret — generate a secure random string:
#   openssl rand -hex 32
SESSION_SECRET=change-this-to-a-secure-random-string-in-production

# ── OPTIONAL ──

# PostgreSQL connection string (leave empty for SQLite local dev)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/labcoop

# Admin access token (legacy — admin now uses session-based auth)
# ADMIN_TOKEN=

# CORS allowed origins (comma-separated)
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Mail config (for admin OTP password reset)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_SCHEME=smtps
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM_NAME=LabCoop Admin
# MAIL_FROM_ADDRESS=your@email.com

# PayMongo payment gateway
# PAYMONGO_SECRET=sk_test_xxx
# PAYMONGO_PUBLIC=pk_test_xxx
