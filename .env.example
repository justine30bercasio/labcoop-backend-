PORT=3000
# Database — uncomment for PostgreSQL, leave commented for local SQLite
# DATABASE_URL=postgres://user:password@host:port/dbname
JWT_SECRET=change-this-to-a-secure-random-string-in-production
ADMIN_TOKEN=change-this-to-a-secure-random-token
NODE_ENV=development

# Admin dashboard login
ADMIN_EMAIL=admin@labcoop.app
ADMIN_PASSWORD_HASH=$2b$10$placeholder
SESSION_SECRET=change-this-to-a-secure-random-string-in-production

# Resend for OTP / email notifications
# Sign up at https://resend.com, create API key
# Free tier: 100 emails/day, from address defaults to onboarding@resend.dev
# For production: verify your own domain in Resend dashboard
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# MAIL_FROM_NAME=MySYS

# Cloudflare R2 Object Storage (file uploads — shop/board/profile/KYC images)
# R2_PUBLIC_URL is the r2.dev subdomain or custom domain for your bucket
# Enable Public Access in R2 Dashboard → labcoop → Settings → Public Access
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=labcoop
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# QStash — scheduled job runner (signing keys from https://console.upstash.com/qstash)
# QSTASH_CURRENT_SIGNING_KEY=...
# QSTASH_NEXT_SIGNING_KEY=...

# PayMongo payment gateway (optional — leave blank to disable)
# PAYMONGO_SECRET=sk_test_xxxxxxxxx
# PAYMONGO_PUBLIC=pk_test_xxxxxxxxx
# PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxx

# Firebase Cloud Messaging (optional — set path to service account JSON)
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# Sentry error monitoring (optional — leave blank to disable)
# Get DSN from https://sentry.io
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Database backup (optional — defaults to 30 max backups retained)
# MAX_BACKUPS=30

# CORS — comma-separated list of allowed origins (defaults to localhost + Render)
# CORS_ORIGIN=http://localhost:3000,https://labcoop-backend.onrender.com

# Rate limiting — set lower in production (requests per window)
# LOGIN_RATE_LIMIT_MAX=5
# DEPOSIT_RATE_LIMIT_MAX=10
