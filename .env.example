# Server port
PORT=3000

# JWT secret — generate a secure random string (e.g., openssl rand -hex 32)
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Admin access token — set a secure token to protect /admin and /api/excel routes
# If empty, admin routes return 403. Generate with: openssl rand -hex 16
ADMIN_TOKEN=

# PostgreSQL connection string (for future PG migration — currently unused)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/labcoop

# Environment
NODE_ENV=development
