{
  "name": "labcoop-backend",
  "version": "1.0.0",
  "description": "LabCoop Gamified Cooperative Passbook API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node db/migrate-sqlite.js",
    "seed": "node db/seed-sqlite.js",
    "migrate:pg": "node db/migrate.js",
    "seed:pg": "node db/seed.js",
    "docker:build": "docker build -t labcoop-backend ..",
    "docker:run": "docker-compose up -d",
    "pm2:start": "pm2 start ../ecosystem.config.js",
    "pm2:stop": "pm2 stop labcoop-backend",
    "backup": "bash ../scripts/backup.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1094.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.3",
    "puppeteer": "^25.3.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1"
  }
}
